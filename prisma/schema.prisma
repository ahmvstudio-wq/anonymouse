datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}







model User {
  id           String              @id @default(uuid()) 
  systemId     String              @unique
  role String
  status String
  passwordHash String
  createdAt    DateTime            @default(now())
  
  identity    IdentityMapping?
  tokens      RefreshToken[]
  projects    Project[]           @relation("ClientProjects")
  assignments ProjectAssignment[]
}

model IdentityMapping {
  id            String   @id @default(uuid()) 
  userId        String   @unique 
  encryptedData Bytes
  iv            Bytes
  authTag       Bytes
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(uuid()) 
  userId    String    
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String              @id @default(uuid()) 
  name        String
  clientId    String              
  createdAt   DateTime            @default(now())
  
  client      User                @relation("ClientProjects", fields: [clientId], references: [id])
  assignments ProjectAssignment[]
  channel     Channel?
  files       FileRecord[]
}

model ProjectAssignment {
  projectId  String   
  userId     String   
  assignedAt DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Channel {
  id        String    @id @default(uuid()) 
  projectId String    @unique 
  
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String   @id @default(uuid()) 
  channelId      String   
  senderSystemId String
  content        String
  createdAt      DateTime @default(now())
  
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model FileRecord {
  id               String          @id @default(uuid()) 
  projectId        String          
  uploaderSystemId String
  s3Key            String
  originalName     String
  mimeType         String
  createdAt        DateTime        @default(now())
  
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accessLogs       FileAccessLog[]
}

model FileAccessLog {
  id             String     @id @default(uuid()) 
  fileId         String     
  actorSystemId  String
  action String
  createdAt      DateTime   @default(now())
  
  file           FileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)
}
